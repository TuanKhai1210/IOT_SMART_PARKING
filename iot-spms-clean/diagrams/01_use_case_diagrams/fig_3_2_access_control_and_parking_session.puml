@startuml
left to right direction

skinparam backgroundColor white
skinparam shadowing false
skinparam packageStyle rectangle
skinparam ArrowThickness 1
skinparam nodesep 35
skinparam ranksep 35
skinparam defaultTextAlignment center

skinparam actor {
  BackgroundColor white
  BorderColor black
  FontSize 11
}

skinparam usecase {
  BackgroundColor white
  BorderColor black
  FontSize 11
}

actor "University\nMember" as User
actor "Parking\nOperator" as Operator

User -[hidden]down- Operator

rectangle "\nAccess Control and Parking Session" {

  usecase "Authenticate\nMember" as UC1
  usecase "Authorize Parking\nAccess" as UC2
  usecase "Manage Parking\nEntry" as UC3
  usecase "Manage Parking\nExit" as UC4
  usecase "Create / Validate\nParking Session" as UC5
  usecase "Record Entry /\nExit Event" as UC6
  usecase "Control Gate" as UC7
  usecase "Handle Access\nException" as UC8

  UC1 -[hidden]right- UC2
  UC2 -[hidden]right- UC5

  UC3 -[hidden]right- UC4
  UC4 -[hidden]right- UC6

  UC5 -[hidden]down- UC3
  UC6 -[hidden]right- UC7
  UC8 -[hidden]down- UC3
}

actor "HCMUT_SSO" as SSO
actor "HCMUT_DATACORE" as DATA
actor "Gate\nController" as Gate

SSO -[hidden]down- DATA
DATA -[hidden]down- Gate

User --> UC3
User --> UC4

Operator --> UC8

SSO --> UC1
DATA --> UC2
Gate --> UC7

UC3 ..> UC1 : <<include>>
UC3 ..> UC2 : <<include>>
UC3 ..> UC5 : <<include>>
UC3 ..> UC6 : <<include>>
UC3 ..> UC7 : <<include>>

UC4 ..> UC1 : <<include>>
UC4 ..> UC5 : <<include>>
UC4 ..> UC6 : <<include>>
UC4 ..> UC7 : <<include>>

UC8 ..> UC3 : <<extend>>
UC8 ..> UC4 : <<extend>>

@enduml