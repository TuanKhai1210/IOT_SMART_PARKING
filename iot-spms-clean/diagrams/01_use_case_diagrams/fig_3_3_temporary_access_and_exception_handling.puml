@startuml
left to right direction

skinparam backgroundColor white
skinparam shadowing false
skinparam packageStyle rectangle
skinparam ArrowThickness 1
skinparam nodesep 35
skinparam ranksep 35
skinparam defaultTextAlignment center

skinparam actor {
  BackgroundColor white
  BorderColor black
  FontSize 11
}

skinparam usecase {
  BackgroundColor white
  BorderColor black
  FontSize 11
}

actor "Visitor /\nNo-ID User" as Visitor
actor "Parking\nOperator" as Operator

Visitor -[hidden]down- Operator

rectangle "\nTemporary Access and Exception Handling" {

  usecase "Request Temporary\nAccess" as UC1
  usecase "Issue Temporary\nTicket" as UC2
  usecase "Create Temporary\nSession" as UC3
  usecase "Validate Temporary\nExit" as UC4
  usecase "Calculate Temporary\nFee" as UC5
  usecase "Resolve Lost Card /\nLost Ticket" as UC6
  usecase "Manual Gate\nOverride" as UC7
  usecase "Record Exception\nLog" as UC8

  UC1 -[hidden]right- UC2
  UC2 -[hidden]right- UC3

  UC4 -[hidden]right- UC5
  UC5 -[hidden]right- UC8

  UC3 -[hidden]down- UC4
  UC6 -[hidden]down- UC7
}

actor "Gate\nController" as Gate

Visitor --> UC1
Visitor --> UC4

Operator --> UC2
Operator --> UC6
Operator --> UC7

Gate --> UC7

UC1 ..> UC2 : <<include>>
UC2 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
UC6 ..> UC4 : <<extend>>
UC7 ..> UC8 : <<include>>
UC6 ..> UC8 : <<include>>

@enduml